# Frontend — Variables de entorno
# Renombrar a .env y completar con los valores reales de tu proyecto Firebase.
# Estas variables son expuestas al navegador (prefijo VITE_).

# URL del backend FastAPI
VITE_API_URL=http://localhost:8000

# Firebase Web SDK Configuration
# Obtener desde: Firebase Console → Proyecto → Configuración → Apps web → SDK Config
VITE_FIREBASE_API_KEY=REEMPLAZAR_CON_TU_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
