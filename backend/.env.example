# Renombrar este archivo a .env y completar los valores

# Ruta al archivo JSON de credenciales de Firebase Admin SDK
# Descargarlo desde: Firebase Console > Proyecto > Configuración > Cuentas de servicio
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# ID del proyecto Firebase
FIREBASE_PROJECT_ID=tu-proyecto-firebase

# Nombre de la colección en Firestore donde se guardan las facturas
INVOICES_COLLECTION=invoices

# Puerto del servidor (default: 8000)
PORT=8000
