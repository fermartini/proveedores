# Renombrar este archivo a .env y completar los valores

# Ruta al archivo JSON de credenciales de Firebase Admin SDK
# Descargarlo desde: Firebase Console > Proyecto > Configuración > Cuentas de servicio
# Credenciales de Firebase (Opción A: Archivo local)
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Credenciales de Firebase (Opción B: JSON string - Recomendado para Hugging Face/Producción)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "...", ...}'

# ID del proyecto Firebase
FIREBASE_PROJECT_ID=tu-proyecto-firebase

# Nombre de la colección en Firestore donde se guardan las facturas
INVOICES_COLLECTION=invoices

# Puerto del servidor (default: 8000)
PORT=8000

# --- FALLBACK DE IA (OPCIONAL pero recomendado) ---
# API Key de Google Gemini para activar el análisis multimodal de facturas sin QR.
# Obtener GRATIS en: https://aistudio.google.com/app/apikey
# Si no se configura, las facturas sin QR quedarán marcadas como "sin_qr".
GEMINI_API_KEY=TU_API_KEY_AQUI
